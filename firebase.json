{
  "functions": {
    "source": "functions",
    "codebase": "default",
    "ignore": ["node_modules", ".git"],
    "predeploy": ["npm --prefix \"$RESOURCE_DIR\" run build"]
  },
  "storage": {
    "rules": "storage.rules"
  },
  "firestore": {
    "database": "(default)",
    "location": "us-east1",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": "out",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/formatwithai",
        "function": "formatwithai",
        "region": "us-east1"
      },
      {
        "source": "/api/regenerateimage",
        "function": "regenerateimage",
        "region": "us-east1"
      },
      {
        "source": "/api/generatecontent",
        "function": "generatecontent",
        "region": "us-east1"
      },
      {
        "source": "/api/getarticles",
        "function": "getarticles",
        "region": "us-east1"
      },
      {
        "source": "/api/getarticle",
        "function": "getarticle",
        "region": "us-east1"
      },
      {
        "source": "/api/createarticle",
        "function": "createarticle",
        "region": "us-east1"
      },
      {
        "source": "/api/updatearticle",
        "function": "updatearticle",
        "region": "us-east1"
      },
      {
        "source": "/api/deletearticle",
        "function": "deletearticle",
        "region": "us-east1"
      },
      {
        "source": "/api/listcovers",
        "function": "listcovers",
        "region": "us-east1"
      },
      {
        "source": "/api/uploadcover",
        "function": "uploadcover",
        "region": "us-east1"
      },
      {
        "source": "**",
        "destination": "/404.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      }
    ]
  }
}
